{
  "name": "my-cloudhub-portal",
  "version": "0.0.1",
  "scripts": {
    "prepare": "npm run smui-theme-light && npm run smui-theme-dark",
    "smui-theme-light": "smui-theme compile static/smui.css -i src/theme -i ./node_modules",
    "smui-theme-dark": "smui-theme compile static/smui-dark.css -i src/theme/dark -i ./node_modules",
    "dev": "vite dev  --port 4210",
    "lint": "eslint",
    "e2e": "playwright test",
    "test": "vitest",
    "build": "vite build",
    "build:mcp": "tsc --project tsconfig.mcp.json",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "mcp:start": "tsx src/lib/mcp/server.ts",
    "mcp:example": "tsx src/lib/mcp/server.ts https://petstore.swagger.io/v2/swagger.json",
    "mcp:test": "tsx src/lib/mcp/test-mcp-server.ts"
  },
