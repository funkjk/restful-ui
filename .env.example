# Build mode (set at build time, not usually in .env for local dev)
# BUILD_MODE=static   # static hosting (GitHub Pages)
# BUILD_MODE=server   # default — API routes, proxy, ConfigStore, MCP

# Config persistence: fs | upstash | postgres | inmemory
# - fs: local files (mcp-configs/)
# - upstash: Vercel KV (KV_REST_API_*)
# - postgres: PostgreSQL via DATABASE_URL
STORE_TYPE=fs

# Required when STORE_TYPE=postgres
DATABASE_URL=

# Required when STORE_TYPE=upstash (Vercel Marketplace injects these)
KV_REST_API_URL=
KV_REST_API_TOKEN=
